{
  "name": "claude-chat",
  "version": "1.0.0",
  "description": "Transparent Claude terminal app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.duck343.claude-chat",
    "productName": "Claude Chat",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
